{
    "name": "@verichain-nexus/web",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/web",
    "projectType": "application",
    "tags": [
        "type:app",
        "scope:web"
    ],
    "targets": {
        "build": {
            "executor": "@nx/next:build",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "apps/web/.next"
            }
        }
    }
}